{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tauri-appcode-visual-verse",
  "version": "0.1.0",
  "identifier": "com.codevisualverse.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Code Visual Verse",
        "width": 1280,
        "height": 800,
        "center": true,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "both",
        "displayLanguageSelector": true
      },
      "wix": {
        "language": [
          "zh-CN",
          "en-US"
        ]
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.13"
    }
  }
}
